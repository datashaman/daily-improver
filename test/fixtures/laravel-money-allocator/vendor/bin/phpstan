#!/usr/bin/env php
<?php

declare(strict_types=1);

if (in_array('--version', $argv, true)) {
    fwrite(STDOUT, "PHPStan - PHP Static Analysis Tool 2.1.0\n");
    exit(0);
}

fwrite(STDOUT, json_encode([
    'totals' => ['errors' => 0, 'file_errors' => 0],
    'files' => new stdClass(),
    'errors' => [],
], JSON_THROW_ON_ERROR));
exit(0);
